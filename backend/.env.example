# Baza podataka (PostgreSQL)
# Lokalno: postgresql://korisnik:lozinka@localhost:5432/rezervacije
# Prisma lokalni Postgres: npx prisma dev (pa koristi generisani URL iz .env)
DATABASE_URL="postgresql://korisnik:lozinka@localhost:5432/rezervacije"

# JWT tajna (generiši nasumičan string za produkciju)
JWT_SECRET="tajna-za-jwt-promijeni-u-produkciji"

# Port API servera (opcionalno)
PORT=4000
